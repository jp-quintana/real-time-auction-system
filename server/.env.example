# Loaded by @nestjs/config. Copy to server/.env and fill in.

NODE_ENV=development
PORT=3000

# Only needed for host-side use (npm run start:dev or drizzle-kit from server/).
# Inside docker-compose this is overridden to point at the `db` service.
# DATABASE_URL=postgres://<user>:<password>@localhost:<dbport>/<dbname>

# Generate with `openssl rand -hex 64`
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_TTL=7d

# 15 * 60 * 1000
ACCESS_TOKEN_COOKIE_MAX_AGE=900000
# 7 * 24 * 60 * 60 * 1000
REFRESH_TOKEN_COOKIE_MAX_AGE=604800000